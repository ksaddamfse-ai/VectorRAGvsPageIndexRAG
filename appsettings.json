{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ProviderRegistry": {
    "ActiveEmbeddingProvider": "NvidiaNim",
    "ActiveEmbeddingModel": "nvidia/nv-embed-v1",
    "OpenRouter": {
      "Type": "OpenAI",
      "Enabled": true,
      "ApiKey": "",
      "BaseUrl": "https://openrouter.ai/api/v1",
      "Models": ["openrouter/free", "google/gemma-4-31b-it:free"]
    },
    "NvidiaNim": {
      "Type": "OpenAI",
      "Enabled": true,
      "ApiKey": "",
      "BaseUrl": "https://integrate.api.nvidia.com/v1",
      "Models": ["meta/llama-3.3-70b-instruct"]
    },
    "FoundryLocal": {
      "Type": "OpenAI",
      "Enabled": true,
      "ApiKey": "",
      "BaseUrl": "http://localhost:52789/v1",
      "Models": ["Phi-4-mini-reasoning-cuda-gpu:3"]
    },
    "Ollama": {
      "Type": "OpenAI",
      "Enabled": true,
      "ApiKey": "ollama",
      "BaseUrl": "http://localhost:11434/v1",
      "Models": []
    }
  },
  "VectorStoreRegistry": {
    "ActiveProvider": "Qdrant",
    "Qdrant": {
      "Type": "Qdrant",
      "DefaultCollectionName": "documents",
      "ChunkSize": 512,
      "ChunkOverlap": 51,
      "Host": "localhost",
      "Port": 6334
    },
    "AzureAISearch": {
      "Type": "AzureAISearch",
      "DefaultCollectionName": "documents",
      "ChunkSize": 512,
      "ChunkOverlap": 51,
      "Endpoint": "",
      "ApiKey": ""
    }
  }
}
